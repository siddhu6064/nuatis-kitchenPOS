# Nuatis POS prototype — local dev env vars
# Copy to .env and fill in values before running.

# Base URL of the pos-api server (no trailing slash).
# For local dev: http://localhost:3002
# For Replit deployed: /api
VITE_API_BASE_URL=http://localhost:3002

# Demo tenant + location + staff UUIDs (from supabase/seed.sql)
# Pre-filled on the sign-in screen.
VITE_DEMO_TENANT_ID=00000000-0000-0000-0000-000000000001
VITE_DEMO_LOCATION_ID=00000000-0000-0000-0000-000000000010
VITE_DEMO_STAFF_ID=00000000-0000-0000-0000-000000000020

# Supabase anon key — required for KDS Realtime channel subscription.
# Get these from `supabase start` output (local dev) or Supabase project settings.
# Broadcast channels are public-by-default; auth-gating is a future hardening step.
# Leave blank to disable KDS Realtime (KDS will show "Waiting for orders…" only).
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=
