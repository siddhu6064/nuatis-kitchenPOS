# ============================================================
# pos-api environment variables
# Copy to .env and fill in values before starting the server.
# Variables marked [required] must be set for production.
# Variables marked [optional] fall back to mock/no-op mode if absent.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development             # development | production | test
LOG_LEVEL=info                   # trace | debug | info | warn | error | fatal

# [required] Secret for signing POS JWTs (session + terminal tokens).
# Generate: openssl rand -base64 48
POS_JWT_SECRET=

# [optional] Allowed CORS origins (comma-separated).
# Required only when pos-admin runs on a different origin (local dev).
# Example: http://localhost:3001
CORS_ALLOWED_ORIGINS=

# ── Database (Supabase) ───────────────────────────────────────
# [required] Supabase project URL and service role key.
# Without these, the API starts in mock mode (DB routes return 503).
# Find both in: Supabase Dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Receipt delivery — Redis queue (Upstash / BullMQ) ────────
# [optional] Upstash Redis URL (rediss://...) for async receipt jobs.
# Without this, receipt delivery workers run in no-op mock mode.
UPSTASH_REDIS_URL=

# ── Receipt delivery — Email (Resend) ────────────────────────
# [optional] Resend API key (re_...) from resend.com.
# Without this, email delivery is skipped in mock mode.
RESEND_API_KEY=

# [optional] Public-facing base URL used to build /r/:token receipt view links.
# Set to your API domain in production.
RECEIPT_BASE_URL=http://localhost:3002

# [optional] HS256 secret for signing receipt view tokens (min 32 bytes).
# Falls back to POS_JWT_SECRET when absent. Set separately in production.
RECEIPT_TOKEN_SECRET=

# ── Receipt delivery — SMS (Telnyx) ──────────────────────────
# [optional] Telnyx API key and sending number (E.164) for SMS receipts.
# Without these, SMS delivery is skipped in mock mode.
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=+15550000000

# ── Stripe Connect + Terminal ─────────────────────────────────
# [optional] Stripe secret key (sk_test_... in test mode, sk_live_... in prod).
# Without this, all Stripe routes return 503.
STRIPE_SECRET_KEY=

# [optional] Stripe webhook endpoint signing secret (whsec_...).
# Obtain from: Stripe Dashboard → Developers → Webhooks → your endpoint.
# Without this, webhook signatures are NOT verified (unsafe for production).
STRIPE_WEBHOOK_SECRET=

# [optional] Your Stripe platform account ID (acct_...).
# Visible in Stripe Dashboard → top-right account selector.
STRIPE_PLATFORM_ACCOUNT_ID=

# [optional] OAuth redirect URLs for Stripe Connect Standard onboarding flow.
STRIPE_CONNECT_RETURN_URL=http://localhost:3001/settings
STRIPE_CONNECT_REFRESH_URL=http://localhost:3001/settings

# ── Error monitoring (Sentry) ─────────────────────────────────
# [optional] Sentry DSN for server-side error capture.
# Without this, Sentry is disabled — no console output, no errors.
# Obtain from: https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=
