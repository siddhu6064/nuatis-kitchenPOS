# Copy to .env and fill in. Never commit .env.

PORT=3002
NODE_ENV=development

# Fill in when Supabase project is linked (Dashboard → Settings → API)
SUPABASE_URL=
# from Supabase Dashboard → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

LOG_LEVEL=info

# JWT signing secret — 32+ random bytes. Generate with: openssl rand -base64 32
# DEV ONLY example (regenerate for production):
# POS_JWT_SECRET=R3pL4c3M3W1thAR3alS3cr3tOf32PlusChars==
POS_JWT_SECRET=

# ---------------------------------------------------------------------------
# Receipt delivery — all optional; mock mode runs without any of them
# ---------------------------------------------------------------------------

# Upstash Redis URL (rediss://...) — required for BullMQ receipt workers.
# When absent: workers run in no-op mock mode.
UPSTASH_REDIS_URL=

# Resend API key (re_...) from resend.com — required for real email delivery.
# When absent: emails are logged to stdout in mock mode.
RESEND_API_KEY=

# Telnyx credentials — required for real SMS delivery.
# TELNYX_FROM_NUMBER must be in E.164 format (+1XXXXXXXXXX).
TELNYX_API_KEY=
TELNYX_FROM_NUMBER=

# Public-facing base URL used to build /r/:token receipt links.
# Set to your API domain in production (e.g. https://api.example.com).
RECEIPT_BASE_URL=http://localhost:3002

# HS256 secret for signing receipt tokens (32+ bytes).
# Defaults to POS_JWT_SECRET when absent. Set separately in production.
RECEIPT_TOKEN_SECRET=

# ---------------------------------------------------------------------------
# Stripe Connect + Terminal — all optional; routes return 503 in mock mode
# ---------------------------------------------------------------------------

# Stripe secret key (sk_test_... for test mode).
# Required for real Stripe payments, Terminal, and Connect onboarding.
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...).
# Obtain from Stripe Dashboard → Developers → Webhooks → your endpoint.
STRIPE_WEBHOOK_SECRET=

# Your Stripe platform account ID (acct_...) — visible in Dashboard.
STRIPE_PLATFORM_ACCOUNT_ID=

# URLs Stripe redirects to after Connect onboarding completes or fails.
STRIPE_CONNECT_RETURN_URL=http://localhost:3001/settings
STRIPE_CONNECT_REFRESH_URL=http://localhost:3001/settings
