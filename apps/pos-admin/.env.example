# ============================================================
# pos-admin environment variables
# Copy to .env.local and fill in values before starting the server.
# Variables marked [required] must be set for production.
# Variables marked [optional] fall back to defaults if absent.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
PORT=3001

# [required] Base URL of this Next.js app (used by Auth.js for callbacks).
# In Vercel production this is set automatically — leave blank to let Vercel handle it.
NEXTAUTH_URL=http://localhost:3001

# [required] Secret for Auth.js JWT signing and session encryption.
# Generate: openssl rand -base64 32
# Both names are required — Auth.js v5 reads AUTH_SECRET, v4 reads NEXTAUTH_SECRET.
NEXTAUTH_SECRET=
AUTH_SECRET=

# ── Backend API ───────────────────────────────────────────────
# [required] Server-to-server base URL for pos-api.
# In production, set to the deployed pos-api URL (e.g. https://api.your-domain.com).
POS_API_URL=http://localhost:3002

# ── Error monitoring (Sentry) ─────────────────────────────────
# [optional] Sentry DSN for server-side error capture (Next.js server components,
# API routes, edge middleware). Without this, Sentry is disabled server-side.
# Obtain from: https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=

# [optional] Sentry DSN exposed to the browser for client-side error capture.
# Safe to expose publicly. Usually the same value as SENTRY_DSN.
# Prefix NEXT_PUBLIC_ is required for Next.js to include it in browser bundles.
NEXT_PUBLIC_SENTRY_DSN=
